{
  "version": "0.1",
  "date": "2026-06-15",
  "purpose": "Machine-readable draft rules for A股短线助手 candidate screening and review.",
  "disclaimer": "Research and review aid only. Not investment advice.",
  "screening": {
    "pool_caps": {
      "A": 5,
      "B": 10,
      "C": 20
    },
    "defense_mode": {
      "allow_empty_recommendations": true,
      "empty_when_no_a_pool": true,
      "min_a_score": 85,
      "min_b_score": 60,
      "min_c_score": 45,
      "max_severe_risk_count": 1,
      "description": "底层防御：行情特别差、风险巨大或没有合适股票时，可以不推或少推，空仓优先。"
    },
    "replace_theme_keywords": false,
    "theme_keywords": {
      "电力": ["电力", "火电", "水电", "核电", "风电", "光伏发电", "绿电", "电网", "储能", "虚拟电厂", "特高压"],
      "科技": ["科技", "软件", "信息技术", "人工智能", "AI", "算力", "数据中心", "云计算", "通信", "服务器", "信创", "网络安全", "机器人", "消费电子"],
      "商业航天": ["商业航天", "卫星", "卫星互联网", "火箭", "航天", "北斗导航", "空天信息", "遥感", "导航", "低轨卫星"],
      "半导体": ["半导体", "芯片", "集成电路", "晶圆", "封测", "光刻", "EDA", "存储芯片", "功率半导体", "第三代半导体", "先进封装"],
      "PCB": ["PCB", "印制电路板", "覆铜板", "CCL", "HDI", "载板", "IC 载板", "高速板", "高频板"]
    }
  },
  "workflow": {
    "name": "盘前主题 → 盘中验证 → 尾盘执行",
    "premarket_theme_layer": {
      "purpose": "先确定当天值得观察的方向，只作为优先级加权，不直接构成买点。",
      "inputs": ["海外行业映射", "产业新闻催化", "A股本地强势板块", "重点主题关键词"],
      "pass_rule": "命中电力、科技、商业航天、半导体、PCB等重点主题，或后续接入的盘前主线池。"
    },
    "intraday_validation_layer": {
      "purpose": "确认主题不是只停留在消息层，而是真的有A股量价和分时承接。",
      "checks": ["板块联动", "量比放大", "分时强于均价线", "涨幅不过热", "收盘位置强", "尾盘没有跳水"],
      "pass_rule": "至少出现量能、分时、板块或形态中的两类确认信号。"
    },
    "tail_execution_layer": {
      "purpose": "只把通过前两层过滤的股票交给14:50-14:57尾盘买入策略。",
      "buy_window": "14:50-14:57",
      "preferred_time": "14:52",
      "pass_rule": "必须命中S1/S2/S3/S4之一，并且没有严重过热或尾盘诱多风险；当日涨幅超过6.5%时，还必须满足板块涨停数>=3且有真实尾盘量确认，才允许进入重点关注。"
    }
  },
  "global_rules": {
    "universe": ["sse_main_board_a", "szse_main_board_a"],
    "exclude": ["ST", "*ST", "S*ST", "chi_next", "star_market", "beijing_exchange", "b_share", "delisting"],
    "buy_window": {
      "start": "14:50",
      "end": "14:57",
      "preferred": "14:52"
    },
    "next_day_sell_window": {
      "start": "09:30",
      "end": "10:30"
    },
    "position_size_pct": {
      "max_single_position_min": 10,
      "max_single_position_max": 15
    },
    "stop_loss_pct": {
      "min": -3,
      "max": -2
    },
    "exit_discipline": {
      "low_open_exit": "开盘低开超过-1.5%，9:35前不能修复则卖出。",
      "flat_open_exit": "平开或小幅高开，9:45前站不上分时均价线则卖出。",
      "normal_gap_take_profit": "高开0.5%-3%，冲到第一止盈点先卖50%，剩余仓位跌破分时均价线卖出。",
      "large_gap_exit": "高开超过3%，第一波拉不动优先卖出；若放量继续上攻，只留小仓跟踪。",
      "time_stop": "10:30前未走强，无论盈亏退出或至少降到观察仓。",
      "logic_failure_exit": "板块龙头低开低走、个股跌破分时均价线且无量反抽、早盘冲高回落跌破开盘价，均视为逻辑失效。",
      "moving_take_profit": "浮盈超过+1.5%后止损线上移到买入价；超过+2.5%后止损线上移到+1%；超过+4%后跌破分时均价线卖出。"
    },
    "market_risk_switch": {
      "index_drop_pct": -1.5,
      "action": "reduce_position_or_stay_empty"
    },
    "forbidden_setups": [
      "tail_vertical_spike",
      "late_chase_near_limit_up_or_overheated_gain",
      "force_trade_on_broad_market_crash"
    ]
  },
  "strategies": [
    {
