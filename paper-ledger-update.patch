+      background: #f3f4f6;
+      color: #374151;
+    }
+    .calendar-grid {
+      display: grid;
+      grid-template-columns: repeat(7, minmax(0, 1fr));
+      gap: 6px;
+    }
+    .calendar-head {
+      color: var(--muted);
+      font-size: 12px;
+      font-weight: 800;
+      text-align: center;
+    }
+    .calendar-day {
+      min-height: 68px;
+      border: 1px solid var(--line);
+      border-radius: 8px;
+      background: #fafbfc;
+      padding: 7px;
+      display: grid;
+      align-content: start;
+      gap: 4px;
+      cursor: pointer;
+    }
+    .calendar-day.empty {
+      background: transparent;
+      border-color: transparent;
+      cursor: default;
+    }
+    .calendar-day.today {
+      border-color: var(--blue);
+      box-shadow: inset 0 0 0 1px var(--blue);
+    }
+    .calendar-day.profit {
+      background: #fff5f5;
+      border-color: #efc8c8;
